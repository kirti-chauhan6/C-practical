#include <iostream>
using namespace std;

class Matrix {

    int row, col;
    int a[10][10];

public:

    void input() {

        cout << "Enter rows and columns: ";
        cin >> row >> col;

        cout << "Enter matrix elements:\n";

        for(int i = 0; i < row; i++)
            for(int j = 0; j < col; j++)
                cin >> a[i][j];
    }

    void display() {

        for(int i = 0; i < row; i++) {
            for(int j = 0; j < col; j++)
                cout << a[i][j] << " ";
            cout << endl;
        }
    }

    Matrix add(Matrix m) {

        if(row != m.row || col != m.col)
            throw "Matrices incompatible for addition";

        Matrix temp;
        temp.row = row;
        temp.col = col;

        for(int i = 0; i < row; i++)
            for(int j = 0; j < col; j++)
                temp.a[i][j] = a[i][j] + m.a[i][j];

        return temp;
    }

    Matrix multiply(Matrix m) {

        if(col != m.row)
            throw "Matrices incompatible for multiplication";

        Matrix temp;
        temp.row = row;
        temp.col = m.col;

        for(int i = 0; i < row; i++) {

            for(int j = 0; j < m.col; j++) {

                temp.a[i][j] = 0;

                for(int k = 0; k < col; k++)
                    temp.a[i][j] += a[i][k] * m.a[k][j];
            }
        }

        return temp;
    }

    Matrix transpose() {

        Matrix temp;

        temp.row = col;
        temp.col = row;

        for(int i = 0; i < row; i++)
            for(int j = 0; j < col; j++)
                temp.a[j][i] = a[i][j];

        return temp;
    }
};

int main() {

    Matrix m1, m2, result;
    int choice;

    do {

        cout << "\n1.Add\n2.Multiply\n3.Transpose\n4.Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        try {

            switch(choice) {

                case 1:
                    m1.input();
                    m2.input();

                    result = m1.add(m2);

                    cout << "Sum Matrix:\n";
                    result.display();
                    break;

                case 2:
                    m1.input();
                    m2.input();

                    result = m1.multiply(m2);

                    cout << "Product Matrix:\n";
                    result.display();
                    break;

                case 3:
                    m1.input();

                    result = m1.transpose();

                    cout << "Transpose Matrix:\n";
                    result.display();
                    break;

                case 4:
                    cout << "Exiting...";
                    break;

                default:
                    cout << "Invalid choice";
            }
        }

        catch(const char *msg) {
            cout << msg << endl;
        }

    } while(choice != 4);

    return 0;
}

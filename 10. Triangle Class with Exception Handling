#include <iostream>
#include <cmath>
using namespace std;

class Triangle {

    float a, b, c;

public:

    Triangle(float x, float y, float z) {

        if(x <= 0 || y <= 0 || z <= 0)
            throw "Sides must be greater than zero";

        if((x + y <= z) || (x + z <= y) || (y + z <= x))
            throw "Invalid triangle";

        a = x;
        b = y;
        c = z;
    }

    float area() {

        float s = (a + b + c) / 2;

        return sqrt(s * (s - a) * (s - b) * (s - c));
    }

    bool isRightAngled() {

        float x = a * a;
        float y = b * b;
        float z = c * c;

        return (x + y == z || x + z == y || y + z == x);
    }
};

int main() {

    float a, b, c;

    cout << "Enter sides of triangle: ";
    cin >> a >> b >> c;

    try {

        Triangle t(a, b, c);

        cout << "Area = " << t.area() << endl;

        if(t.isRightAngled())
            cout << "Triangle is right angled";
        else
            cout << "Triangle is not right angled";
    }

    catch(const char *msg) {
        cout << msg;
    }

    return 0;
}
